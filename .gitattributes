# Normalize all text files to LF in the repo, checkout as LF on all platforms
* text=auto eol=lf

# Ensure binary files are never normalized
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.glb binary
*.gltf binary
*.mp3 binary
*.ogg binary
*.wav binary
*.wasm binary
*.woff binary
*.woff2 binary
*.ttf binary
